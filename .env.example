# ================================================================
#  MBS COMUNICACIONES — Variables de entorno
#  Copia este archivo como .env y completa los valores
# ================================================================

# Servidor
PORT=3000
NODE_ENV=development
# URL pública del sitio (sin / final). Se usa para construir las URLs de
# retorno/cancelación de PayPal. Si se deja vacío, se infiere del request.
APP_URL=http://localhost:3000

# Base de datos PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mbs_comunicaciones
DB_USER=postgres
DB_PASSWORD=tu_password_aqui

# JWT - Autenticación
JWT_SECRET=cambia_esto_por_una_clave_muy_larga_y_segura_2025
JWT_EXPIRES_IN=7d

# PayPal (dejar vacío hasta configurar)
# PAYPAL_MODE: "sandbox" para pruebas, "live" para producción
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
# Webhook ID registrado en el Dashboard de PayPal (Apps & Credentials → tu app → Webhooks)
# Si se deja vacío, no se verifica la firma de los webhooks entrantes
PAYPAL_WEBHOOK_ID=

# SPEI: la CLABE, banco y beneficiario NO se configuran aquí.
# Se guardan en la tabla `configuracion` y se editan desde el panel
# de administración (Configuración > Pagos).

# Email (SMTP) - usado para el correo de "recuperar contraseña".
# Si se deja vacío, el envío se omite (se loguea una advertencia) sin
# que falle la solicitud de recuperación.
# Ejemplo con Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_SECURE=false,
# SMTP_USER=tu_correo@gmail.com, SMTP_PASS=contraseña de aplicación (no la normal)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=MBS Comunicaciones <no-reply@mbscomunicaciones.mx>
